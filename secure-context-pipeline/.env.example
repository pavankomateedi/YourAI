# Copy to .env and fill in values. NEVER commit .env (see .gitignore).

# --- LLM provider (use one) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
LLM_PROVIDER=anthropic                 # "anthropic" | "openai"
LLM_MODEL=claude-3-5-sonnet-20241022

# --- Storage ---
VAULT_DB_PATH=./data/vault.db          # SQLite path for the encrypted vault
STORE_DB_PATH_DIR=./data/documents     # Directory for encrypted document blobs
STORE_ENCRYPTION_KEY_PATH=./data/master.key  # AES-256 master key file

# --- Session / obfuscation ---
SESSION_TIMEOUT_MINUTES=30
CONFIDENCE_THRESHOLD=0.60              # Below this -> [REDACTED], not a token
OBFUSCATION_STRATEGY=tokenization     # "tokenization" | "pseudonymization"

# --- Logging ---
LOG_LEVEL=INFO
AUDIT_LOG_PATH=./data/audit.jsonl

# --- Optional: KMS for production key wrapping ---
# AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:...
